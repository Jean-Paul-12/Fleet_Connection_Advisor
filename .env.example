FLASK_ENV=development
FLASK_APP=app.main
PORT=5000

SUPABASE_URL=
# Required for backend persistence. Get it from Supabase Dashboard > Project Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=
# Optional: publishable/anon key (used only if you add direct frontend Supabase access)
SUPABASE_ANON_KEY=

WEATHER_API_PROVIDER=weatherstack
# Free key: https://weatherstack.com/signup
WEATHER_API_KEY=
WEATHER_API_BASE_URL=http://api.weatherstack.com

BASE_COST_PER_TRIP=1.0
RAIN_COST_MULTIPLIER=1.3
STORM_COST_MULTIPLIER=1.5
NORMAL_COST_MULTIPLIER=1.0

TARGET_CONNECTION_RATE=0.95
DEFAULT_ESTIMATED_COST_PER_COURIER_ACTIVATION=5.0

SIMULATION_MIN_BASE_ORDERS=8000
SIMULATION_MAX_BASE_ORDERS=15000
SIMULATION_ORDERS_PER_COURIER=4
SIMULATION_MAX_RAIN_DEMAND_UPLIFT=0.20
SIMULATION_MAX_RAIN_AVAILABILITY_DROP=0.25

LOW_RISK_RAIN_THRESHOLD=0.3
MEDIUM_RISK_RAIN_THRESHOLD=0.6
HIGH_RISK_RAIN_THRESHOLD=0.75

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://fleet-connection-advisor-view.vercel.app
